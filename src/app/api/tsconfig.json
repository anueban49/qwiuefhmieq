{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "paths": {
      "@lib/*": ["../lib/*"]
    }
  },
  "include": ["src/**/*", "../lib/**/*"],
  "exclude": ["node_modules"]
}
